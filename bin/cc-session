#!/usr/bin/env bash
# cc-session — attach or create a persistent Claude Code session in tmux.
#
# Run the Claude Code TUI inside a named, detachable tmux session so it survives
# disconnects (close your laptop, drop SSH) and you can reattach later. Pairs well
# with SSH: run `ssh -t host cc-session <project>` and the TUI renders in your
# local terminal while the agent + tools execute on the remote host. See `cc-remote`
# for a config-driven wrapper around that.
#
# Part of cc-tools: https://github.com/caezium/cc-tools
set -euo pipefail

BASE="${CC_BASE:-$HOME/Desktop}"   # where bare project names / the picker look

# Find the claude binary: $CLAUDE_BIN, then PATH, then common install locations.
find_claude() {
  if [ -n "${CLAUDE_BIN:-}" ] && [ -x "$CLAUDE_BIN" ]; then echo "$CLAUDE_BIN"; return; fi
  if command -v claude >/dev/null 2>&1; then command -v claude; return; fi
  for c in "$HOME/.local/bin/claude" "/opt/homebrew/bin/claude" "/usr/local/bin/claude"; do
    [ -x "$c" ] && { echo "$c"; return; }
  done
  echo ""
}

usage() {
  cat <<EOF
cc-session — persistent Claude Code sessions in tmux

Usage:
  cc-session                 interactive picker (search running sessions + projects)
  cc-session pick            same picker, explicitly
  cc-session <project>       attach/create for \$BASE/<project>   (BASE=$BASE)
  cc-session <abs-path>      attach/create for an absolute path
  cc-session .               use the current directory
  cc-session ls              list running cc sessions
  cc-session kill <project>  kill a session
  cc-session candidates      machine-readable list (used by cc-remote)

Picker uses fzf if installed, otherwise a numbered menu.
Detach from a live session with:  Ctrl-b  then  d
Env: CC_BASE (project root, default ~/Desktop), CLAUDE_BIN (path to claude)
EOF
}

list_sessions() { tmux ls 2>/dev/null | grep '^cc-' || echo "(no running cc sessions)"; }

# Emit candidate dirs, one per line, prefixed "● " (running session) or "  " (project).
candidates() {
  local seen="|"
  if command -v tmux >/dev/null 2>&1; then
    while IFS=$'\t' read -r sname spath; do
      case "$sname" in
        cc-*) [ -n "$spath" ] || continue
              printf '● %s\n' "$spath"; seen="$seen$spath|" ;;
      esac
    done < <(tmux list-sessions -F '#{session_name}'$'\t''#{session_path}' 2>/dev/null)
  fi
  local d
  for d in "$BASE"/*/; do
    [ -d "$d" ] || continue
    d="${d%/}"
    case "$seen" in *"|$d|"*) continue ;; esac
    # By default only show real projects (a repo or an existing Claude workspace);
    # set CC_ALL_DIRS=1 to list every subdirectory of $BASE.
    if [ "${CC_ALL_DIRS:-0}" != "1" ]; then
      [ -d "$d/.git" ] || [ -d "$d/.claude" ] || continue
    fi
    printf '  %s\n' "$d"
  done
}

# Read candidate lines on stdin, let the user choose one, print the chosen line.
choose() {
  local lines=() line
  while IFS= read -r line; do lines+=("$line"); done
  [ "${#lines[@]}" -eq 0 ] && { echo "no sessions or projects found under $BASE" >&2; return 1; }
  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "${lines[@]}" | fzf --prompt='cc-session> ' --height=40% --reverse --no-multi
  else
    local i=1
    for line in "${lines[@]}"; do printf '%3d) %s\n' "$i" "$line" >&2; i=$((i+1)); done
    printf 'select [1-%d]: ' "${#lines[@]}" >&2
    local n; read -r n </dev/tty || return 1
    case "$n" in (*[!0-9]*|'') return 1 ;; esac
    [ "$n" -ge 1 ] && [ "$n" -le "${#lines[@]}" ] && printf '%s\n' "${lines[$((n-1))]}"
  fi
}

# Resolve a chosen candidate line ("● /path" or "  /path") to its dir, then run us on it.
pick() {
  local chosen; chosen="$(candidates | choose)" || return 1
  [ -n "$chosen" ] || return 1
  exec "$0" "${chosen:2}"   # strip the 2-char marker
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
  ls|list)        list_sessions; exit 0 ;;
  candidates)     candidates; exit 0 ;;
  pick)           pick; exit $? ;;
  kill)
    [ -n "${2:-}" ] || { echo "usage: cc-session kill <project>" >&2; exit 1; }
    tmux kill-session -t "cc-$2" 2>/dev/null && echo "killed cc-$2" \
      || { echo "no session cc-$2" >&2; exit 1; }
    exit 0 ;;
esac

command -v tmux >/dev/null 2>&1 || { echo "cc-session needs tmux (brew install tmux)" >&2; exit 1; }

target="${1:-}"

# No argument: launch the picker when interactive; else fall back sensibly.
if [ -z "$target" ]; then
  if [ -t 0 ] || [ -t 1 ]; then pick; exit $?; fi
  running="$(tmux ls 2>/dev/null | grep -c '^cc-' || true)"
  if [ "${running:-0}" -eq 1 ]; then
    name="$(tmux ls 2>/dev/null | grep '^cc-' | head -1 | cut -d: -f1)"
    exec tmux new-session -A -s "$name"
  fi
  dir="$BASE"
elif [ "$target" = "." ]; then
  dir="$PWD"
elif [ -d "$target" ]; then
  dir="$target"
elif [ -d "$BASE/$target" ]; then
  dir="$BASE/$target"
else
  echo "No such project/dir: '$target' (looked in $BASE)" >&2
  echo "Running sessions:" >&2; list_sessions >&2
  exit 1
fi
dir="$(cd "$dir" && pwd)"
name="cc-$(basename "$dir")"

claude_bin="$(find_claude)"
[ -n "$claude_bin" ] || { echo "cc-session: could not find the 'claude' binary (set CLAUDE_BIN)" >&2; exit 1; }
CC_CMD="${CC_CMD:-${SHELL:-/bin/sh} -l -c '$claude_bin'}"

if [ "${CC_DRY:-0}" = "1" ]; then
  echo "would attach/create session '$name' in '$dir' running: $CC_CMD"
  exit 0
fi

if [ -n "${TMUX:-}" ]; then
  tmux has-session -t "$name" 2>/dev/null \
    || tmux new-session -d -s "$name" -c "$dir" "$CC_CMD"
  exec tmux switch-client -t "$name"
fi

exec tmux new-session -A -s "$name" -c "$dir" "$CC_CMD"
